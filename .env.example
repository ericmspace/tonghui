# ===== 阿里云 DashScope / 百炼 MaaS 配置（示例）=====
# 复制为 .env 并填入真实值。
#
# 重要：密钥若从聊天/文档粘贴，常因换行被截断，请核对首尾完整。
# 端点形态以阿里云官方文档为准；service 层(app/services/*.server.ts)已做成易调形态。

DASHSCOPE_API_KEY=sk-ws-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_WORKSPACE=ws-xxxxxxxxxxxxxxxx
DASHSCOPE_BASE=https://<workspace>.cn-beijing.maas.aliyuncs.com
DASHSCOPE_IMAGE_BASE=https://<workspace>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

MODEL_IMAGE=qwen-image-2.0
MODEL_VIDEO=happyhorse-1.1-i2v
MODEL_VISION=qwen-vl-max
MODEL_TEXT=qwen-plus
MODEL_TTS=cosyvoice-v1

# ── 语音引导 TTS：火山引擎/豆包语音（暖音色）──────────────────
# 凭证来自火山「语音技术」控制台（与方舟 Ark 的 ark- key 不同！）。
# 不填则语音引导自动回退浏览器朗读。
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts
# 暖/豆包音色：BV700_streaming(灿灿) | zh_female_tianmeixiaoyuan_moon_bigtts(甜美小源,大模型,更像豆包)
VOLC_TTS_VOICE=BV700_streaming
VOLC_TTS_ENCODING=mp3
VOLC_TTS_SPEED=0.95

# true = 不发真实请求，全部走 Mock 兜底（适合纯前端演示/无网环境）
USE_MOCK=false
